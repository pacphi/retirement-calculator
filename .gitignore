# Dependencies & package-manager state
node_modules/
.pnpm-store/
pnpm-debug.log*

# Build output
dist/

# Test coverage
coverage/

# Editor & OS cruft
.DS_Store

# AI agent tooling — machine-local state, caches, and databases.
# These are regenerated per machine/session and are not meant to be shared.
.agentic-qe/
.claude-flow/
# Ignore everything under .claude/ EXCEPT the project-specific skill(s) we author
# in this repo, which are version-controlled so they travel with the project.
# Using globs (not a bare `.claude/`) lets git descend so the negations apply.
.claude/*
!.claude/skills/
.claude/skills/*
!.claude/skills/calculator-comparison/
.swarm/
ruvector.db

# Local MCP server configuration — may contain machine-specific paths or credentials.
.mcp.json

# Audit/test scratch & generated reports (not part of the committed project)
/reports/
/.stryker-tmp/
/audits/
